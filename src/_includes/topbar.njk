<header class="topbar">
  <div class="wrap topbar__in">
    <a class="brand" href="/" aria-label="{{ site.company.name }} home">
      <svg class="mark" viewBox="0 0 32 32" fill="none" aria-hidden="true">
        <rect x="1" y="1" width="30" height="30" rx="4" fill="#14222D"/>
        <path d="M9 22c0-5 4-9 9-9m-9 9V10m0 12h12" stroke="#C06B3E" stroke-width="2.4" stroke-linecap="round"/>
        <circle cx="22" cy="13" r="3" stroke="#4FA6B8" stroke-width="2.2"/>
      </svg>
      <span>{{ site.company.name }}<small>{{ site.company.tagline }}</small></span>
    </a>
    <nav class="nav" aria-label="Primary">
      <a href="/#services">Services</a>
      <a href="/#process">How it works</a>
      <a href="/#reviews">Reviews</a>
      <a href="/#quote">Get a quote</a>
    </nav>
    <a class="phone" href="tel:{{ site.company.phone_link }}"><span>●</span> {{ site.company.phone_display }}</a>
  </div>
</header>
